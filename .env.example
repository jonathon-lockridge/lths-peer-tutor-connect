# =============================================
# LTHS Peer Tutor Connect — Environment Variables
# Copy this file to server/.env and client/.env
# =============================================

# --- SERVER (.env in /server) ---

# PostgreSQL connection string
# Local: postgresql://USER:PASSWORD@localhost:5432/lths_peer_tutor
# Railway/Render: provided in dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/lths_peer_tutor"

# Clerk — Backend Secret Key (Settings → API Keys)
CLERK_SECRET_KEY="sk_test_..."

# Clerk — Webhook Secret (Clerk Dashboard → Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET="whsec_..."

# Port for Express server (default 3001)
PORT=3001

# URL of the frontend (for CORS)
CLIENT_URL="http://localhost:5173"

# Node environment
NODE_ENV="development"

# Comma-separated list of personal emails that receive admin role
ADMIN_EMAILS="you@example.com"

# Email (Resend) — get free API key at resend.com
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LTHS Peer Tutor Connect <noreply@student-tutors.com>"

# --- Cloud File Storage (Cloudflare R2 — recommended, free tier available) ---
# Leave these blank to use local disk storage in development.
# In production on Railway, local disk is wiped on every deploy, so R2 is required.
#
# Setup: cloudflare.com → R2 → Create bucket → API Tokens → Create token (Object Read & Write)
# S3_ENDPOINT: found in R2 bucket settings (format: https://<account-id>.r2.cloudflarestorage.com)
# S3_PUBLIC_URL: your bucket's public URL (enable "Public access" in R2 bucket settings)
S3_BUCKET_NAME=""
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""


# --- CLIENT (.env in /client) ---

# Clerk — Publishable Key (Settings → API Keys)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Backend URL (if not proxying through Vite)
VITE_API_URL="http://localhost:3001"
