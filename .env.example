# =============================================
# LTHS Peer Tutor Connect — Environment Variables
# Copy this file to server/.env and client/.env
# =============================================

# --- SERVER (.env in /server) ---

# PostgreSQL connection string
# Local: postgresql://USER:PASSWORD@localhost:5432/lths_peer_tutor
# Railway/Render: provided in dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/lths_peer_tutor"

# Clerk — Backend Secret Key (Settings → API Keys)
CLERK_SECRET_KEY="sk_test_..."

# Clerk — Webhook Secret (Clerk Dashboard → Webhooks → your endpoint → Signing Secret)
CLERK_WEBHOOK_SECRET="whsec_..."

# Port for Express server (default 3001)
PORT=3001

# URL of the frontend (for CORS)
CLIENT_URL="http://localhost:5173"

# Node environment
NODE_ENV="development"


# --- CLIENT (.env in /client) ---

# Clerk — Publishable Key (Settings → API Keys)
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."

# Backend URL (if not proxying through Vite)
VITE_API_URL="http://localhost:3001"
